<section class="container">
  <p>Storefront Product</p>
  <div id="storefront-product">

  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', async () => {
    const container = document.getElementById('storefront-product');

    const storefrontAccessToken = 'fc22fee3e0bec5d1dde8e71357196ba0';
    const shop = '{{ shop.domain }}';
    const productHandle = '{{ section.settings.product.handle }}';

    const query = `
      query {
        product(handle: "${productHandle}") {
          title
          description
          images(first: 1) {
            edges {
              node {
                url
                altText
              }
            }
          }
          variants(first: 1) {
            edges {
              node {
                id
                price {
                  amount
                }
              }
            }
          }
        }
      }
    `;

    try {
      const response = await fetch(`https://${shop}/api/2024-04/graphql.json`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-Shopify-Storefront-Access-Token': storefrontAccessToken,
        },
        body: JSON.stringify({ query }),
      });

      const result = await response.json();
      const product = result.data.product;

      if (!product) {
        container.innerHTML = '<p>Product not found.</p>';
        return;
      }

      const image = product.images.edges[0]?.node?.url || '';
      const alt = product.images.edges[0]?.node?.altText || product.title;
      const price = product.variants.edges[0]?.node?.price.amount || '';
      const variantId = product.variants.edges[0]?.node?.id;

      // Shopify AJAX API requires numeric variant ID (not GID) — extract it
      const numericVariantId = variantId?.split('/').pop();

      container.innerHTML = `
        <div>
          <img src="${image}" alt="${alt}" style="width: 150px; height: auto;" />
          <h2 style="font-size: 20px;margin-top: 10px;">${product.title}</h2>
          <p><strong>$${price}</strong></p>
          <button id="add-to-cart" style="cursor:pointer; padding: 0.5rem 1rem; background: black; color: white; border: none; cursor: pointer;">
            Add to cart
          </button>
          <p id="cart-message" style="color: green;"></p>
        </div>
      `;

      const button = document.getElementById('add-to-cart');
      const message = document.getElementById('cart-message');

      button.addEventListener('click', async () => {
        const response = await fetch('/cart/add.js', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Accept': 'application/json'
          },
          body: JSON.stringify({
            id: numericVariantId,
            quantity: 1
          })
        });

        if (response.ok) {
          const data = await response.json();
          message.textContent = `${data.title} was added to your cart.`;

          // Dispatch the event with added product
          window.dispatchEvent(new CustomEvent('cart:added', {
            detail: {
              product: data
            }
          }));
        } else {
          const error = await response.json();
          message.textContent = error.message || 'Failed to add to cart.';
          message.style.color = 'red';
        }
      });

    } catch (error) {
      container.innerHTML = '<p>Error loading product.</p>';
      console.error(error);
    }
  });
</script>

{% schema %}
{
  "name": "Product Storefront",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Product",
    }
  ],
  "presets": [
    {
      "name": "Product Storefront"
    }
  ]
}
{% endschema %}
