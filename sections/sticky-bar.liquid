{{ 'section-sticky-bar.css' | asset_url | stylesheet_tag }}

{% liquid
	if section.index == 1
    assign preload = true
  else
    assign preload = false
  endif

  if section.index <= 2
    assign loading = 'eager'
    assign fetchpriority = 'high'
  else
    assign loading = 'lazy'
    assign fetchpriority = 'auto'
  endif

  if section.settings.product != blank
    assign product = section.settings.product
  else
    assign product = product
  endif

  assign variant = product.selected_or_first_available_variant
%}

{% style %}
  {% comment %} Section Padding {% endcomment %}
  .section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top | append: 'px' }};
    padding-bottom: {{ section.settings.padding_bottom | append: 'px' }};
  }
  @media screen and (max-width: 750px) {
    .section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top_mobile | append: 'px' }};
      padding-bottom: {{ section.settings.padding_bottom_mobile | append: 'px' }};
    }

    {% if section.settings.show_product_price_in_btn %}
      .section-{{ section.id }} .sb-product-info {
        justify-content: space-between;
        grid-column: 1/3;
      }
    {% endif %}
  }

  .section-{{ section.id }} {
    --sb-bg-color: {{ section.settings.bg_color }};
    --sb-text-color: {{ section.settings.text_color }};

    background-color: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};

    {% if section.settings.border_top %}
      border-top: 1px solid {{ section.settings.text_color }};
    {% endif %}
  }
  .section-{{ section.id }} .sb-product-image {
    width: {{ section.settings.product_image_width | append: 'px' }};
  }
{% endstyle %}


<sticky-bar
  data-variant-change="{{ section.settings.change_product_info_on_variant_switch }}"
  data-section-id="{{ section.id }}"
  data-trigger-selector="{{ section.settings.trigger_selector_id | strip | escape }}"
>
  <div class="section-{{ section.id }} sb-wrapper">
    {% if section.settings.product_image != blank %}
      {% render 'image-snippet',
        image: section.settings.product_image,
        alt: section.settings.product_image.alt,
        preload: preload,
        fetchpriority: fetchpriority,
        loading: loading,
        class: 'sb-product-image',
        max_width: 280
      %}
    {% endif %}

    <div class="sb-product-info">
      {%if section.settings.product_title != blank %}
        <h3 class="sb-product-title">{{ section.settings.product_title }}</h3>
      {% endif %}

      {% if section.settings.show_reviews %}
        <div class="sb-reviews-block">
        {% render 'review-stars',
          rating_value: section.settings.rating_value,
          rating_text: section.settings.reviews_text,
          star_use_svg: section.settings.use_svg,
          star_svg_code_icon: section.settings.svg_code_icon,
          star_image_icon: section.settings.image_icon,
          preload: preload,
          loading: loading,
          fetchpriority: fetchpriority
        %}
      </div>
      {% endif %}
    </div>

    {% if section.settings.show_product_price and section.settings.show_product_price_in_btn != true and variant != nil %}
      <div class="sb-price">
        <span class="sb-price-item" data-base-price="{{ variant.price }}">{{ variant.price | money_without_trailing_zeros }}</span>
        <span class="sb-price-compare-item {% if variant.compare_at_price == nil %}hidden{% endif %}" data-base-compare-price="{{ variant.compare_at_price | default: 0 }}">{{ variant.compare_at_price | money_without_trailing_zeros }}</span>
      </div>
    {% endif %}
    {% if section.settings.show_btn %}
      {% if section.settings.btn_type == 'atc' and section.settings.btn_text != blank and variant != nil %}
        <button
          class="atc-button"
          data-variant-id="{{ variant.id }}"
          data-qty="1"
          id="sticky-add-to-cart-{{ section.id }}"
          {% if variant.available == false %}
            disabled
          {% endif %}
        >
          <span class="text">
            <span>{{ section.settings.btn_text }}</span>
            {% if section.settings.show_product_price_in_btn %}
              <span class="sb-price-item" data-base-price="{{ variant.price }}">&nbsp;{{ variant.price | money_without_trailing_zeros }}</span>
            {% endif %}
          </span>

          {% comment %} {% render 'loading-spinner', class: 'loader' %} {% endcomment %}
        </button>
      {% elsif section.settings.btn_type == 'link' and section.settings.btn_link != blank and section.settings.btn_url != blank %}
        <a href="{{ section.settings.btn_url }}" class="link-button">
          {{ section.settings.btn_text }}
        </a>
      {% endif %}
    {% endif %}
  </div>
</sticky-bar>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    if (!customElements.get('sticky-bar')) {
      class StickyBar extends HTMLElement {
        connectedCallback() {
          this._stickyBar = this.querySelector(`.section-${this.dataset.sectionId}`);
          this._atcButton = this.querySelector('.atc-button');
          this._triggerSelector = this.dataset.triggerSelector || '';
          this.variantChangeOn = this.dataset.variantChange || '';

          this._initVisibility();
          this._initFooterObserver();
          if (this.dataset.variantChange === 'true') this._bindVariantChange();
          if (this._atcButton) this._bindAtcButton();
        }

        disconnectedCallback() {
          this._observer?.disconnect();
          this._footerObserver?.disconnect();
        }

        _initVisibility() {
          const triggerSelector = this._triggerSelector.trim();

          if (!triggerSelector) {
            // No trigger configured — show immediately by default
            this._stickyBar.classList.add('show');
            return;
          }

          const triggerEl = document.querySelector(triggerSelector);
          if (triggerEl) {
            // show stickyBar when trigger element reached viewport
            this._observer = new IntersectionObserver(
              (entries) => {
                this._stickyBar.classList.toggle('show', entries[0].isIntersecting);
              },
              { root: null, threshold: 0.1 }
            );
            this._observer.observe(triggerEl);
          } else {
            // selector provided but element not found — show immediately
            this._stickyBar.classList.add('show');
          }
        }

        _initFooterObserver() {
          const footer = document.querySelector('.shopify-section-group-footer-group, footer');
          // hide when stickyBar reached footer
          if(footer) {
            this._footerObserver = new IntersectionObserver(
              (entries) => {
                this._stickyBar.classList.toggle('show', !entries[0].isIntersecting);
              },
              { root: null, threshold: 0.1 }
            );
            this._footerObserver.observe(footer);
          }
        }

        _bindVariantChange() {
          document.addEventListener('variant:changed', (event) => {


            const variantData = event.detail?.variant;
            if (!variantData) return;

            if (this._atcButton) {
              this._atcButton.dataset.variantId = variantData.id;
            }

            const productImage = this._stickyBar.querySelector('.sb-product-image');
            if (productImage) {
              productImage.src = variantData.featured_image;
              productImage.srcset = '';
            }

            this._updatePrice(variantData);
          });
        }

        _updatePrice(variantData = null) {
          const priceItem = this._stickyBar.querySelector('.sb-price-item');
          const comparePriceItem = this._stickyBar.querySelector('.sb-price-compare-item');
          if (!priceItem) return;

          if (variantData) {
            const newPrice = Number(variantData.price || 0);
            priceItem.dataset.basePrice = isNaN(newPrice) ? 0 : newPrice;

            if (comparePriceItem) {
              const newComparePrice = Number(variantData.compare_at_price || 0);
              comparePriceItem.dataset.baseComparePrice = isNaN(newComparePrice) ? 0 : newComparePrice;
            }
          }

          const basePrice = Number(priceItem.dataset.basePrice || 0);
          priceItem.textContent = this._formatMoney(basePrice);

          if (comparePriceItem) {
            const baseCompare = Number(comparePriceItem.dataset.baseComparePrice || 0);
            if (baseCompare > basePrice) {
              comparePriceItem.textContent = this._formatMoney(baseCompare);
              comparePriceItem.classList.remove('hidden');
            } else {
              comparePriceItem.classList.add('hidden');
            }
          }
        }

        _formatMoney(cents) {
          const rate = window.Shopify?.currency?.rate ?? 1;
          return new Intl.NumberFormat('{{ localization.language.iso_code }}-{{ localization.country.iso_code }}', {
            style: 'currency',
            currency: '{{ localization.country.currency.iso_code }}',
            minimumFractionDigits: 0,
            maximumFractionDigits: 0,
          }).format(Math.round(rate * (cents / 100)));
        }


        _bindAtcButton() {
          this._atcButton.addEventListener('click', async () => {
            this._atcButton.classList.add('loading');
            try {
              const items = [{ id: this._atcButton.dataset.variantId, quantity: +this._atcButton.dataset.qty }];

              const response = await fetch('/cart/add.js', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ items }),
              });

              const data = await response.json();

              document.dispatchEvent(new CustomEvent('cart:added', {
                detail: { item: data.items ? data.items[0] : data }
              }));
            } catch (e) {
              console.error(e);
            } finally {
              this._atcButton.classList.remove('loading');
            }
          });
        }
      }

      customElements.define('sticky-bar', StickyBar);
    }
  })
</script>

{% schema %}
  {
    "name": "Sticky bar",
    "limit": 1,
    "settings": [
      {
        "type": "text",
        "id": "trigger_selector_id",
        "label": "Trigger selector ID",
        "info": "Enter the selector of the element that triggers the sticky bar appearance. Example: [id^='ProductSubmitButton-']. If no selector is provided, the sticky bar will be shown on scroll."
      },
      {
        "type": "checkbox",
        "id": "border_top",
        "label": "Border top",
        "default": true
      },
      {
        "type": "color",
        "id": "text_color",
        "label": "Text color",
        "default": "#231F20",
        "info": "not appplies to ATC button"
      },
      {
        "type": "color",
        "id": "bg_color",
        "label": "BG color",
        "default": "#F0F2F1"
      },
      {
        "type": "header",
        "content": "Product settings"
      },
      {
        "type": "product",
        "id": "product",
        "label": "Product"
      },
      {
        "type": "checkbox",
        "id": "change_product_info_on_variant_switch",
        "label": "Change product info on variant switch",
        "default": true,
        "info": "please dispatch updated variant info to 'variant:changed' event"
      },
      {
        "type": "image_picker",
        "id": "product_image",
        "label": "Product image"
      },
      {
        "type": "range",
        "id": "product_image_width",
        "min": 60,
        "max": 160,
        "step": 1,
        "unit": "px",
        "label": "Product image width",
        "default": 80
      },
      {
        "type": "text",
        "id": "product_title",
        "label": "Product title"
      },
      {
        "type": "checkbox",
        "id": "show_product_price",
        "label": "Show product price",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "show_product_price_in_btn",
        "label": "Show product price in btn",
        "visible_if": "{{ section.settings.show_product_price == true }}",
        "default": true
      },
      {
        "type": "header",
        "content": "Button settings"
      },
      {
        "type": "checkbox",
        "id": "show_btn",
        "label": "Show button",
        "default": true
      },
      {
        "type": "text",
        "id": "btn_text",
        "label": "Button text",
        "default": "Add to cart",
        "visible_if": "{{ section.settings.show_btn == true }}"
      },
      {
        "type": "select",
        "id": "btn_type",
        "label": "Button type",
        "options": [
          {
            "value": "atc",
            "label": "ATC"
          },
          {
            "value": "link",
            "label": "Link"
          }
        ],
        "default": "atc",
        "visible_if": "{{ section.settings.show_btn == true }}"
      },
      {
        "type": "url",
        "id": "btn_url",
        "label": "Button URL",
        "visible_if": "{{ section.settings.btn_type == 'link' }}"
      },
      {
        "type": "header",
        "content": "Reviews settings"
      },
      {
        "type": "checkbox",
        "id": "show_reviews",
        "label": "Show reviews",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "use_svg",
        "label": "Use SVG code star icon",
        "default": true
      },
      {
        "type": "liquid",
        "id": "svg_code_icon",
        "label": "SVG code icon",
        "visible_if": "{{ section.settings.use_svg  }}"
      },
      {
        "type": "image_picker",
        "id": "image_icon",
        "label": "Star icon image",
        "visible_if": "{{ section.settings.use_svg == false }}"
      },
      {
        "type": "text",
        "id": "rating_value",
        "label": "Rating value"
      },
      {
        "type": "text",
        "id": "reviews_text",
        "label": "Reviews text",
        "default": "Reviews"
      },
      {
        "type": "header",
        "content": "Section padding"
      },
      {
        "type": "range",
        "id": "padding_top",
        "min": 0,
        "max": 100,
        "step": 1,
        "unit": "px",
        "label": "Padding top",
        "default": 12
      },
      {
        "type": "range",
        "id": "padding_bottom",
        "min": 0,
        "max": 100,
        "step": 1,
        "unit": "px",
        "label": "Padding bottom",
        "default": 12
      },
      {
        "type": "range",
        "id": "padding_top_mobile",
        "min": 0,
        "max": 100,
        "step": 1,
        "unit": "px",
        "label": "Padding top mobile",
        "default": 8
      },
      {
        "type": "range",
        "id": "padding_bottom_mobile",
        "min": 0,
        "max": 100,
        "step": 1,
        "unit": "px",
        "label": "Padding bottom mobile",
        "default": 8
      }
    ],
    "presets": [
      {
        "name": "Sticky bar"
      }
    ]
  }
{% endschema %}